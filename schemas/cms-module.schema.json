{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mirassolprevi.com.br/schemas/cms-module.schema.json",
  "title": "Configuração de módulo do CMS Mirassol-Previ",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "key", "name", "description", "data", "identity", "fields", "ui", "operations", "serialization"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "key": { "$ref": "#/$defs/key" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string", "minLength": 1, "maxLength": 300 },
    "data": {
      "type": "object",
      "required": ["file", "publicPage", "adapter", "collectionPath", "groups"],
      "properties": {
        "file": { "type": "string", "pattern": "^[A-Za-z0-9._/-]+\\.json$" },
        "publicPage": { "type": "string", "pattern": "^[A-Za-z0-9._/-]+\\.html$" },
        "adapter": { "enum": ["array", "grouped", "matrix"] },
        "collectionPath": { "type": "array", "items": { "$ref": "#/$defs/key" } },
        "groups": { "type": "array", "items": { "$ref": "#/$defs/key" } },
        "valueField": { "$ref": "#/$defs/key" },
        "sort": { "type": "array", "items": { "$ref": "#/$defs/sort" } }
      }
    },
    "identity": {
      "type": "object",
      "required": ["field", "parts"],
      "properties": {
        "field": { "$ref": "#/$defs/key" },
        "prefix": { "type": "string" },
        "parts": {
          "type": "array", "minItems": 1,
          "items": {
            "type": "object", "required": ["field"],
            "properties": { "field": { "$ref": "#/$defs/key" }, "transform": { "enum": ["month-number", "slug"] } }
          }
        },
        "immutable": { "type": "array", "items": { "$ref": "#/$defs/key" } }
      }
    },
    "fields": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object", "required": ["key", "label", "type"],
        "properties": {
          "key": { "$ref": "#/$defs/key" }, "label": { "type": "string" },
          "type": { "enum": ["text", "textarea", "url", "number", "select", "date"] },
          "required": { "type": "boolean" }, "group": { "type": "boolean" },
          "options": { "type": "array", "items": { "type": ["string", "number"] } },
          "optionsRange": { "type": "object", "required": ["min", "max"], "properties": { "min": { "type": "integer" }, "max": { "type": "integer" } } },
          "validators": { "type": "array", "items": { "type": "object", "required": ["name"] } }
        }
      }
    },
    "ui": {
      "type": "object", "required": ["search", "filters", "columns", "sort"],
      "properties": {
        "search": { "type": "array", "items": { "$ref": "#/$defs/key" } },
        "filters": { "type": "array", "items": { "$ref": "#/$defs/key" } },
        "columns": { "type": "array", "items": { "type": "object", "required": ["field"], "properties": { "field": { "$ref": "#/$defs/key" }, "label": { "type": "string" }, "format": { "enum": ["text", "code", "link"] }, "linkLabel": { "type": "string" }, "warnDuplicates": { "type": "boolean" } } } },
        "sort": { "type": "array", "items": { "$ref": "#/$defs/sort" } }
      }
    },
    "operations": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["create", "update", "delete"] } },
    "serialization": { "type": "object", "properties": { "style": { "enum": ["pretty", "compact-records"] }, "preserveEol": { "type": "boolean" } } }
  },
  "$defs": {
    "key": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,49}$" },
    "sort": { "type": "object", "required": ["field", "direction"], "properties": { "field": { "$ref": "#/$defs/key" }, "direction": { "enum": ["asc", "desc"] }, "type": { "enum": ["text", "number", "month"] } } }
  }
}
